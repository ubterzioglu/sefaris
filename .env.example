# Sefaris — ortam değişkenleri (rehber bölüm 18). Kopyala → .env / Coolify secrets.

# === UYGULAMA ===
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://sefaris.site
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# === VERİTABANI (backend) ===
DATABASE_URL=jdbc:postgresql://localhost:5432/sefaris_db
DATABASE_USER=sefaris
DATABASE_PASSWORD=sefaris
DATABASE_POOL_SIZE=20
DB_PASSWORD=sefaris

# === KİMLİK DOĞRULAMA ===
JWT_SECRET=your-256-bit-secret-key-here-min-32-bytes-please-change
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# Google OAuth (Faz 2)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://sefaris.site/api/v1/auth/google/callback

# === DOSYA DEPOLAMA (S3 / MinIO) ===
S3_ENABLED=false
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=sefaris-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=eu-central-1
S3_PUBLIC_URL=http://localhost:9000/sefaris-documents

# === E-POSTA (SMTP / SendGrid / SES) ===
EMAIL_ENABLED=false
EMAIL_FROM=noreply@sefaris.site
EMAIL_FROM_NAME=Sefaris
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# === ADMIN PANEL (tek-şifre girişi) ===
# Admin paneline SADECE bu şifreyle girilir (e-posta yok). Prod'da mutlaka değiştir.
ADMIN_EMAIL=admin@sefaris.site
ADMIN_PASSWORD=Sefaris2026!

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === LOGGING ===
LOG_LEVEL=INFO
