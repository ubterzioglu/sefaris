# Copy to .env.local and fill in real values. .env.local is git-ignored.
# In Coolify, set these as environment variables / secrets.

# ---- Supabase (public — safe for the browser) ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ---- Supabase (secret — server-side only, bypasses RLS) ----
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---- Direct Postgres (psql / migrations only) ----
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# ---- Supabase CLI / management API only (not used at runtime) ----
SUPABASE_ACCESS_TOKEN=sbp_xxx

# ---- App ----
# Optional ISO launch date for the countdown (defaults to 30 days from build).
# NEXT_PUBLIC_LAUNCH_DATE=2026-08-01T09:00:00Z

# Fallback file store used only when Supabase env vars are absent.
# SUBSCRIBERS_PATH=/data/subscribers.json

# ---- DETR admin board (/detr) — separate Supabase project ----
# Data (todos/comments/attachments) lives in the ubt2026 project.
UBT_SUPABASE_URL=https://your-ubt-ref.supabase.co
UBT_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Shared gate password (fail-closed if unset).
ADMIN_QASS_DETR=change-me
# Optional comma-separated allowlist override (replaces the built-in default).
# DETR_ALLOWED_EMAILS=someone@example.com,other@example.com
