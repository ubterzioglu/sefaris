# Optional: ISO 8601 launch date for the countdown.
# If unset, the countdown defaults to 30 days from build time.
# Example:
# NEXT_PUBLIC_LAUNCH_DATE=2026-08-01T09:00:00Z

# Where the /api/subscribe route persists emails.
# In Coolify, mount a persistent volume at /data and keep this default.
# SUBSCRIBERS_PATH=/data/subscribers.json
